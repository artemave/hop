#!/usr/bin/env bash
# @vicinae.schemaVersion 1
# @vicinae.title Hop window
# @vicinae.description Focus or create a window in the currently focused hop session. No-op when not on a hop workspace.
# @vicinae.mode silent

set -euo pipefail

ws=$(swaymsg -t get_workspaces | jq -r '.[] | select(.focused).name')

if [[ $ws != p:* ]]; then
    exit 0
fi

session=${ws#p:}
project_root=$(hop list --json 2>/dev/null | jq -r --arg s "$session" '
    .[] | select(.name == $s) | .project_root // empty
' || true)

if [[ ! -d $project_root ]]; then
    exit 0
fi

windows=$(cd "$project_root" && hop windows)

if [ -z "$windows" ]; then
    exit 0
fi

if ! chosen=$(printf '%s\n' "$windows" | vicinae dmenu --placeholder "Hop window"); then
    exit 0
fi

if [ -z "$chosen" ]; then
    exit 0
fi

cd "$project_root"
case "$chosen" in
    editor) exec hop edit ;;
    browser) exec hop browser ;;
    *) exec hop term --role "$chosen" ;;
esac
