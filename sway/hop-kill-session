#!/usr/bin/env bash
# Kill the hop session whose workspace is currently focused.
#
# Bind in sway, e.g.:
#
#     bindsym $mod+Shift+k exec /path/to/hop/sway/hop-kill-session
#
# Useful when the session shells live inside a container or remote backend
# where `hop` itself isn't installed, so you can't run `hop kill` from inside
# the session terminal.

set -e

ws=$(swaymsg -t get_workspaces | jq -r '.[] | select(.focused).name')

if [[ $ws != p:* ]]; then
    exit 0
fi

project_root=$(hop list --json 2>/dev/null | jq -r --arg s "${ws#p:}" '
    .[] | select(.name == $s) | .project_root // empty
' || true)

if [[ ! -d $project_root ]]; then
    exit 0
fi

cd "$project_root" && exec hop kill
